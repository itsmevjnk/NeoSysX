{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "PRINTF_ALIAS_STANDARD_FUNCTION_NAMES_HARD=1",
                "PRINTF_INCLUDE_CONFIG_H=1"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-ffreestanding",
                "-Wall",
                "-Wextra"
            ]
        }
    ],
    "version": 4
}